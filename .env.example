# Copy this file to .env and fill in real values. .env is gitignored.

# Password for the /admin content editor (single shared password, no accounts).
ADMIN_PASSWORD=

# Contact form email delivery. Simplest setup: a Gmail address + an App
# Password (requires 2-Step Verification on the Google account):
# https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASS=

# Optional: only needed for a non-Gmail SMTP provider.
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587

# Optional: override which address receives contact form notifications.
# Defaults to the business email set in /admin (Business Info tab).
# CONTACT_TO_EMAIL=
